(* MLB for the sml-base58 library: the vendored sml-codec core (for Sha256)
 * plus the base58 sources. Consumers reference this file.
 *
 * The dependency .mlb is brought in WITHOUT a `local` wrapper so that
 * consumers (the test suite, examples) can use the codec structures alongside
 * Base58. *)
$(SML_LIB)/basis/basis.mlb
../lib/github.com/sjqtentacles/sml-codec/sml-codec.mlb
base58.sig
base58.sml
