(* MLB for the sml-bip39 library: the vendored sml-crypto core (which itself
 * re-exports the vendored sml-codec, giving us Sha256 / Base16 / Sha512 /
 * Hmac / Pbkdf2) plus the bip39 sources.
 *
 * The dependency .mlb is brought in WITHOUT a `local` wrapper so that
 * consumers (the test suite, examples, sml-bip32) can use the codec/crypto
 * structures alongside Bip39. *)
$(SML_LIB)/basis/basis.mlb
../lib/github.com/sjqtentacles/sml-crypto/sml-crypto.mlb
wordlist.sml
bip39.sig
bip39.sml
